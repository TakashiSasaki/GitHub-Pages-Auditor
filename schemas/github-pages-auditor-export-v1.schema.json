{
  "$ref": "#/definitions/GitHubPagesAuditorExport",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ExportAppMeta": {
      "additionalProperties": false,
      "properties": {
        "environment": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "type": "object"
    },
    "ExportAuditRun": {
      "additionalProperties": false,
      "properties": {
        "finishedAt": {
          "type": [
            "string",
            "null"
          ]
        },
        "githubLogin": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "options": {
          "$ref": "#/definitions/ExportAuditRunOptions"
        },
        "startedAt": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "enum": [
            "queued",
            "running",
            "completed",
            "failed",
            "paused",
            "cancelled"
          ],
          "type": "string"
        },
        "tokenType": {
          "enum": [
            "fine_grained",
            "classic",
            "unknown",
            null
          ],
          "type": [
            "string",
            "null"
          ]
        },
        "userMode": {
          "enum": [
            "google",
            "anonymous"
          ],
          "type": "string"
        }
      },
      "required": [
        "id",
        "status",
        "startedAt",
        "finishedAt",
        "options"
      ],
      "type": "object"
    },
    "ExportAuditRunOptions": {
      "additionalProperties": false,
      "properties": {
        "affiliation": {
          "type": "string"
        },
        "includeArchived": {
          "type": "boolean"
        },
        "includeDisabled": {
          "type": "boolean"
        },
        "includeHealthCheck": {
          "type": "boolean"
        },
        "ownerFilter": {
          "type": [
            "string",
            "null"
          ]
        },
        "strictPagesCheck": {
          "type": "boolean"
        },
        "visibility": {
          "enum": [
            "all",
            "public",
            "private"
          ],
          "type": "string"
        }
      },
      "required": [
        "affiliation",
        "visibility",
        "includeArchived",
        "includeDisabled",
        "strictPagesCheck",
        "includeHealthCheck"
      ],
      "type": "object"
    },
    "ExportClassification": {
      "enum": [
        "pages_disabled",
        "pages_disabled_or_unavailable",
        "pages_enabled_no_custom_domain",
        "custom_domain_configured",
        "custom_domain_verified",
        "custom_domain_pending",
        "custom_domain_unverified_or_unknown",
        "https_certificate_ok",
        "https_certificate_problem_or_unknown",
        "https_not_enforced",
        "dns_health_ok",
        "dns_health_problem",
        "insufficient_permissions",
        "sso_required",
        "rate_limited",
        "api_error",
        "pages_deploy_method_workflow",
        "pages_deploy_method_branch_root",
        "pages_deploy_method_branch_docs",
        "pages_deploy_method_branch_unknown_path",
        "pages_deploy_method_unknown"
      ],
      "type": "string"
    },
    "ExportDomainSummary": {
      "additionalProperties": false,
      "properties": {
        "domain": {
          "type": "string"
        },
        "hasDnsProblem": {
          "type": "boolean"
        },
        "hasDuplicate": {
          "type": "boolean"
        },
        "hasHttpsProblem": {
          "type": "boolean"
        },
        "hasUnverified": {
          "type": "boolean"
        },
        "repositories": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "fullName": {
                "type": "string"
              },
              "pagesSettingsUrl": {
                "type": "string"
              },
              "repositoryTopUrl": {
                "type": "string"
              }
            },
            "required": [
              "fullName",
              "repositoryTopUrl",
              "pagesSettingsUrl"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "repositoryCount": {
          "type": "number"
        }
      },
      "required": [
        "domain",
        "repositoryCount",
        "repositories",
        "hasDuplicate",
        "hasUnverified",
        "hasHttpsProblem",
        "hasDnsProblem"
      ],
      "type": "object"
    },
    "ExportErrorClassification": {
      "enum": [
        "token_invalid_or_expired",
        "insufficient_permissions",
        "sso_required",
        "classic_pat_sso_authorization_required",
        "fine_grained_pat_approval_required",
        "primary_rate_limited",
        "secondary_rate_limited",
        "forbidden_unknown",
        "repository_not_found_or_no_access",
        "pages_not_enabled",
        "pages_resource_not_found",
        "classic_pat_sso_authorization_missing_possible",
        "validation_failed",
        "health_no_cname",
        "endpoint_spam_or_abuse_protection",
        "github_temporary_error",
        "api_error",
        null
      ],
      "type": [
        "string",
        "null"
      ]
    },
    "ExportHealthStatus": {
      "enum": [
        "not_requested",
        "ok",
        "health_pending",
        "health_no_cname",
        "health_custom_domains_unavailable",
        "health_insufficient_permissions",
        "health_dns_problem",
        "health_https_problem",
        "health_https_not_enforced",
        "api_error",
        null
      ],
      "type": [
        "string",
        "null"
      ]
    },
    "ExportPagesDeploymentMethod": {
      "enum": [
        "workflow",
        "branch_root",
        "branch_docs",
        "branch_unknown_path",
        "unknown",
        "not_applicable"
      ],
      "type": "string"
    },
    "ExportRepositoryResult": {
      "additionalProperties": false,
      "properties": {
        "archived": {
          "type": "boolean"
        },
        "buildType": {
          "type": [
            "string",
            "null"
          ]
        },
        "classification": {
          "items": {
            "$ref": "#/definitions/ExportClassification"
          },
          "type": "array"
        },
        "createdAtGitHub": {
          "type": [
            "string",
            "null"
          ]
        },
        "customDomain": {
          "type": [
            "string",
            "null"
          ]
        },
        "customDomainConfigured": {
          "type": "boolean"
        },
        "customDomainVerificationState": {
          "enum": [
            "verified",
            "pending",
            "unverified",
            "unknown",
            "not_applicable"
          ],
          "type": "string"
        },
        "defaultBranch": {
          "type": [
            "string",
            "null"
          ]
        },
        "deploymentMethod": {
          "$ref": "#/definitions/ExportPagesDeploymentMethod"
        },
        "diagnostics": {
          "type": "object"
        },
        "disabled": {
          "type": "boolean"
        },
        "errorClassification": {
          "$ref": "#/definitions/ExportErrorClassification"
        },
        "fork": {
          "type": "boolean"
        },
        "fullName": {
          "type": "string"
        },
        "githubRepoId": {
          "type": [
            "number",
            "null"
          ]
        },
        "hasPages": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "healthStatus": {
          "$ref": "#/definitions/ExportHealthStatus"
        },
        "httpsCertificateDescription": {
          "type": [
            "string",
            "null"
          ]
        },
        "httpsCertificateDomains": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "httpsCertificateExpiresAt": {
          "type": [
            "string",
            "null"
          ]
        },
        "httpsCertificateState": {
          "type": [
            "string",
            "null"
          ]
        },
        "httpsEnforced": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "owner": {
          "type": "string"
        },
        "pagesEnabled": {
          "type": "boolean"
        },
        "pagesPublic": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "pagesSettingsUrl": {
          "type": "string"
        },
        "pagesStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "pagesUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "pendingDomainUnverifiedAt": {
          "type": [
            "string",
            "null"
          ]
        },
        "private": {
          "type": "boolean"
        },
        "protectedDomainState": {
          "type": [
            "string",
            "null"
          ]
        },
        "publishingSourceSummary": {
          "type": [
            "string",
            "null"
          ]
        },
        "pushedAtGitHub": {
          "type": [
            "string",
            "null"
          ]
        },
        "repo": {
          "type": "string"
        },
        "repositoryTopUrl": {
          "type": "string"
        },
        "sourceBranch": {
          "type": [
            "string",
            "null"
          ]
        },
        "sourcePath": {
          "type": [
            "string",
            "null"
          ]
        },
        "updatedAtGitHub": {
          "type": [
            "string",
            "null"
          ]
        },
        "visibility": {
          "enum": [
            "public",
            "private",
            "internal",
            null
          ],
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "githubRepoId",
        "owner",
        "repo",
        "fullName",
        "repositoryTopUrl",
        "pagesSettingsUrl",
        "pagesUrl",
        "private",
        "visibility",
        "archived",
        "disabled",
        "fork",
        "defaultBranch",
        "hasPages",
        "createdAtGitHub",
        "updatedAtGitHub",
        "pushedAtGitHub",
        "pagesEnabled",
        "pagesStatus",
        "buildType",
        "deploymentMethod",
        "sourceBranch",
        "sourcePath",
        "publishingSourceSummary",
        "pagesPublic",
        "customDomain",
        "customDomainConfigured",
        "protectedDomainState",
        "pendingDomainUnverifiedAt",
        "httpsCertificateState",
        "httpsCertificateDescription",
        "httpsCertificateDomains",
        "httpsCertificateExpiresAt",
        "httpsEnforced",
        "healthStatus",
        "classification",
        "errorClassification"
      ],
      "type": "object"
    },
    "ExportSummary": {
      "additionalProperties": false,
      "properties": {
        "approvedCertButHttpsNotEnforcedCount": {
          "type": "number"
        },
        "customDomainCount": {
          "type": "number"
        },
        "customDomainHttpsNotEnforcedCount": {
          "type": "number"
        },
        "customDomainUnverifiedOrUnknownCount": {
          "type": "number"
        },
        "customDomainVerifiedCount": {
          "type": "number"
        },
        "deploymentBranchDocsCount": {
          "type": "number"
        },
        "deploymentBranchRootCount": {
          "type": "number"
        },
        "deploymentUnknownCount": {
          "type": "number"
        },
        "deploymentWorkflowCount": {
          "type": "number"
        },
        "dnsHealthProblemCount": {
          "type": "number"
        },
        "errorCount": {
          "type": "number"
        },
        "httpsNotEnforcedCount": {
          "type": "number"
        },
        "httpsProblemCount": {
          "type": "number"
        },
        "pagesEnabledCount": {
          "type": "number"
        },
        "repositoryCount": {
          "type": "number"
        }
      },
      "required": [
        "repositoryCount",
        "pagesEnabledCount",
        "customDomainCount",
        "customDomainVerifiedCount",
        "customDomainUnverifiedOrUnknownCount",
        "httpsProblemCount",
        "dnsHealthProblemCount",
        "errorCount",
        "deploymentWorkflowCount",
        "deploymentBranchRootCount",
        "deploymentBranchDocsCount",
        "deploymentUnknownCount",
        "httpsNotEnforcedCount",
        "approvedCertButHttpsNotEnforcedCount",
        "customDomainHttpsNotEnforcedCount"
      ],
      "type": "object"
    },
    "GitHubPagesAuditorExport": {
      "additionalProperties": false,
      "properties": {
        "application": {
          "$ref": "#/definitions/ExportAppMeta"
        },
        "auditRun": {
          "$ref": "#/definitions/ExportAuditRun"
        },
        "domains": {
          "items": {
            "$ref": "#/definitions/ExportDomainSummary"
          },
          "type": "array"
        },
        "exportedAt": {
          "type": "string"
        },
        "repositories": {
          "items": {
            "$ref": "#/definitions/ExportRepositoryResult"
          },
          "type": "array"
        },
        "schemaVersion": {
          "const": "github-pages-auditor.export.v1",
          "type": "string"
        },
        "summary": {
          "$ref": "#/definitions/ExportSummary"
        }
      },
      "required": [
        "schemaVersion",
        "exportedAt",
        "application",
        "auditRun",
        "summary",
        "repositories"
      ],
      "type": "object"
    }
  }
}