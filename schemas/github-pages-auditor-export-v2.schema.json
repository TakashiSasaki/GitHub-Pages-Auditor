        "githubId",
        "ownerLogin",
        "name",
        "fullName",
        "htmlUrl",
        "visibility",
        "isPrivate",
        "isArchived",
        "isDisabled",
        "isFork",
        "defaultBranch",
        "githubHasPagesRaw",
        "createdAt",
        "updatedAt",
        "pushedAt"
