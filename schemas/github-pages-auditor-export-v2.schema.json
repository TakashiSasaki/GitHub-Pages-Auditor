    "V2AuditRun": {
      "additionalProperties": false,
      "properties": {
        "finishedAt": {
          "type": [
            "string",
            "null"
          ]
        },
        "githubLogin": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "options": {
          "$ref": "#/definitions/V2AuditRunOptions"
        },
        "startedAt": {
          "type": [
            "string",
            "null"
          ]
