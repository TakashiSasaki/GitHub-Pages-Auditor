                "domains": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "expiresAt": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "stateRaw": {
                  "type": [
                    "string",
                    "null"
                  ]
