        "exportedAt": {
          "type": "string"
        },
        "repositories": {
          "items": {
            "$ref": "#/definitions/V2AuditRepositoryRecord"
          },
          "type": "array"
        },
        "schemaVersion": {
          "const": "github-pages-auditor.export.v2",
          "type": "string"
        },
        "summary": {
          "$ref": "#/definitions/V2Summary"
        }
