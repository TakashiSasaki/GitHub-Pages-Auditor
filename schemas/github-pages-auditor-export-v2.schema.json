        "githubIdNumber": {
          "type": [
            "number",
            "null"
          ]
        },
        "htmlUrl": {
          "type": "string"
        },
        "isArchived": {
          "type": "boolean"
        },
        "isDisabled": {
          "type": "boolean"
        },
        "isFork": {
          "type": "boolean"
        },
        "isPrivate": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        },
        "ownerLogin": {
          "type": "string"
        },
        "pushedAt": {
          "type": [
            "string",
            "null"
          ]
        },
        "updatedAt": {
          "type": [
            "string",
            "null"
          ]
        },
        "visibility": {
          "enum": [
            "public",
            "private",
            "internal",
            "unknown"
