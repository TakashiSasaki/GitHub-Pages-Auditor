          "required": [
            "enforced",
            "certificate"
          ],
          "type": "object"
        },
        "publicRaw": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "settingsUrl": {
          "type": "string"
        },
        "statusRaw": {
          "type": [
            "string",
            "null"
          ]
        }
