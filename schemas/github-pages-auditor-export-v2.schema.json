        },
        "auditRun": {
          "$ref": "#/definitions/V2AuditRun"
        },
        "domains": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "domain": {
                "type": "string"
              },
              "hasDuplicate": {
                "type": "boolean"
              },
              "repositories": {
                "items": {
                  "additionalProperties": false,
                  "properties": {
                    "fullName": {
                      "type": "string"
                    },
                    "htmlUrl": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "fullName",
                    "htmlUrl"
                  ],
                  "type": "object"
                },
                "type": "array"
              },
              "repositoryCount": {
                "type": "number"
              }
            },
            "required": [
              "domain",
              "repositoryCount",
              "repositories",
              "hasDuplicate"
            ],
            "type": "object"
          },
          "type": "array"
